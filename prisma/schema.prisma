generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  @@map("users")
}

enum BanckAccountType {
  CHECKING
  INVESTMENT
  CASH

  @@map("bank_account_type")
}

model BankAccount {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  name           String
  initialBalance Float            @map("initial_balance")
  type           BanckAccountType
  color          String

  @@map("bank_accounts") // Padrao snake_case;
}
